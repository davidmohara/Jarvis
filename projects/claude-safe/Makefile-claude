# Claude Code Docker Environment
# Mount ~/develop/improving so both devbox and ies are accessible
#
# Inside container:
#   /workspace/devbox  ← Claude runs here (WORKDIR)
#   /workspace/ies     ← accessible via ../ies
#
# Usage:
#   make build          Build the Docker image
#   make run            Start container (detached)
#   make claude         Start Claude Code in dangerous mode
#   make shell          Open a bash shell in the container
#   make stop           Stop and remove the container
#   make restart        Stop + run
#   make clean          Remove container and image
#   make status         Show container status

DOCKER_IMAGE_NAME = claude-dev
DOCKER_CONTAINER_NAME = claude-dev
IMPROVING_DIR = $(HOME)/develop/improving

.PHONY: build run stop shell restart clean logs status claude

build:
	docker build -f Dockerfile-claude -t $(DOCKER_IMAGE_NAME) .

run:
	docker run -d \
		--name $(DOCKER_CONTAINER_NAME) \
		-v $(IMPROVING_DIR):/workspace \
		-v $(HOME)/.claude:/root/.claude \
		-e ANTHROPIC_API_KEY \
		-it \
		$(DOCKER_IMAGE_NAME)
	@echo "Container started. Use 'make claude' to launch Claude Code or 'make shell' for bash."

stop:
	docker stop $(DOCKER_CONTAINER_NAME) || true
	docker rm $(DOCKER_CONTAINER_NAME) || true

shell:
	docker exec -it $(DOCKER_CONTAINER_NAME) bash

claude:
	docker exec -it $(DOCKER_CONTAINER_NAME) claude --dangerously-skip-permissions

restart: stop run

clean: stop
	docker rmi $(DOCKER_IMAGE_NAME) || true

logs:
	docker logs -f $(DOCKER_CONTAINER_NAME)

status:
	@docker ps -a --filter name=$(DOCKER_CONTAINER_NAME)
