# TripIt OAuth 1.0a credentials
# Get these by registering an app at TripIt's developer portal
# Then run: npm run auth

TRIPIT_CONSUMER_KEY=your_consumer_key_here
TRIPIT_CONSUMER_SECRET=your_consumer_secret_here
TRIPIT_ACCESS_TOKEN=your_access_token_here
TRIPIT_ACCESS_TOKEN_SECRET=your_access_token_secret_here
