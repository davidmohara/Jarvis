# IES Local Secrets
# Copy this file to config/.env and fill in the values.
# config/.env is gitignored — never committed.

# Slack Bot Token — get from your IES Slack App settings
# https://api.slack.com/apps → Your App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-token-here

# IES Channel Daemon configuration (required)

# Slack channel ID for the ies-channel daemon
# Right-click the channel in Slack → View channel details → copy the channel ID (starts with C)
IES_CHANNEL_ID=C0YOUR_CHANNEL_ID

# Slack user ID of the owner this daemon serves
# Open your Slack profile → three-dot menu → Copy member ID (starts with U)
IES_OWNER_USER_ID=U0YOUR_USER_ID
