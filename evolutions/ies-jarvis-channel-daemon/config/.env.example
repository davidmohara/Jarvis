# IES Local Secrets
# Copy this file to config/.env and fill in the values.
# config/.env is gitignored — never committed.

# Slack Bot Token — get from the Jarvis Slack App settings
# https://api.slack.com/apps → Jarvis → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-token-here

# Jarvis Channel Daemon configuration
# (optional — defaults to David's values if not set)

# Slack channel ID for jarvis-channel daemon (optional)
# Defaults to #jarvis (C0AN2PQNXBR) — set to override
# JARVIS_CHANNEL_ID=C0AN2PQNXBR

# Slack user ID of the owner this daemon serves (optional)
# Defaults to David's ID (U0ANHV5UXEW) — set to override for other IES users
# JARVIS_USER_ID=U0ANHV5UXEW
